---
import { promociones } from '../data/promociones';
---

<section id="promociones" class="section-py" style="background-color: var(--color-surface-low)">
  <div class="site-container">
    <p class="label-sm mb-3" style="color: var(--color-primary)">Aprovechá</p>
    <h2 class="heading-xl text-white mb-12">PROMOCIONES</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {promociones.map(promo => (
        <article class="promo-card flex flex-col gap-4 rounded-xl p-6" style="background-color: var(--color-surface); border: 1px solid var(--color-surface-high)">
          <span
            class="inline-block text-white text-xs font-bold px-3 py-1 rounded-full w-fit"
            style="background-color: var(--color-primary)"
          >
            {promo.badge}
          </span>
          <h3 class="heading-md text-white">{promo.titulo}</h3>
          <p class="text-sm leading-relaxed flex-1" style="color: var(--color-on-surface-muted)">{promo.descripcion}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .promo-card {
    transition: border-color 0.25s ease;
  }
  .promo-card:hover {
    border-color: var(--color-primary) !important;
  }
</style>
