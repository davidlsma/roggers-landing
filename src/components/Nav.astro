---
const navLinks = [
  { href: '/#menu', label: 'Menú' },
  { href: '/#galeria', label: 'Galería' },
  { href: '/#reservas', label: 'Reservaciones' },
  { href: '/#ubicacion', label: 'Ubicación' },
];
const igHref = 'https://instagram.com/roggers.restosj';
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50">
  <nav class="site-container flex items-center justify-between" style="padding-top: 2rem; padding-bottom: 2rem;">
    <!-- Logo -->
    <a href="/" class="nav-logo-text text-white" aria-label="Rogger's — Inicio">
      Rogger's
    </a>

    <!-- Links desktop -->
    <ul class="hidden md:flex items-center gap-8" style="margin-left: auto;" role="list">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="nav-link text-white/60 hover:text-white transition-colors duration-200">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={igHref}
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/60 hover:text-white transition-colors duration-200 flex items-center"
          aria-label="Instagram de Rogger's"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
      </li>
    </ul>

    <!-- Hamburger mobile -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-white p-2"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-white/10 bg-black/95 backdrop-blur-md px-6 pb-8"
  >
    <ul class="flex flex-col" role="list">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="mobile-nav-link text-white/70 hover:text-white transition-colors block border-b border-white/10">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={igHref}
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-nav-link text-white/70 hover:text-white transition-colors flex items-center gap-3"
          aria-label="Instagram de Rogger's"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <span class="label-sm">Instagram</span>
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isHidden));
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden ?? true);
    if (!isHidden) {
      nav?.classList.add('scrolled');
    } else if (window.scrollY <= 80) {
      nav?.classList.remove('scrolled');
    }
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>

<style>
  #main-nav .site-container {
    padding-left: clamp(1rem, 2vw, 1.5rem);
    padding-right: clamp(1rem, 2vw, 1.5rem);
  }
  #main-nav {
    background: transparent;
    border-bottom: 1px solid transparent;
  }
  #main-nav.scrolled {
    background: rgba(0, 0, 0, 0.88);
    border-bottom-color: var(--color-surface-high);
    backdrop-filter: blur(var(--nav-blur));
  }
  .nav-link {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .nav-logo-text {
    font-family: 'Dancing Script', cursive;
    font-size: 2.25rem;
    font-weight: 700;
    text-decoration: none;
    line-height: 1;
  }

  .mobile-nav-link {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
    padding-left: 1rem;
  }
</style>
