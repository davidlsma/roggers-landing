---
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-end" style="padding-bottom: 2.5rem;"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/roggers/principal.jpg"
      alt=""
      loading="eager"
      width="1080"
      height="1350"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-black/20"></div>
  </div>

  <!-- Content -->
  <div class="site-container z-10 w-full text-center">
    <p class="label-sm mb-6" style="color: var(--color-primary)">San Juan · Argentina</p>

    <p class="hero-title mb-8">
      Noches con sabor &amp; buena música
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/#reservas" class="btn-primary">Reservar mesa</a>
      <a
        href="https://menu.fu.do/roggers?utm_source=ig&utm_medium=social&utm_content=link_in_bio&fbclid=PAZXh0bgNhZW0CMTEAc3J0YwZhcHBfaWQMMjU2MjgxMDQwNTU4AAGn5IAEm8q4vS9DAXDjebUGmVugoOz1D_PpSRP2DT3kcMCSFlE8rSa3ztcIrmk_aem_VUQTfV5C7qUgLzsXlaosmg"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost"
      >Ver menú</a>
    </div>
  </div>
</section>

<style>
  .hero-title {
    color: rgba(255,255,255,0.85);
    font-family: 'Bebas Neue', system-ui;
    letter-spacing: 0.04em;
    line-height: 1.05;
    font-size: clamp(2.2rem, 5.5vw, 4rem);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: clamp(1.8rem, 8.5vw, 2.6rem);
    }
  }

  #hero .btn-primary,
  #hero .btn-ghost {
    font-size: 0.7rem;
    padding: 0.7rem 1.4rem;
  }
</style>
