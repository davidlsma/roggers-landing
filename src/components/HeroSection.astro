---
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-end" style="padding-bottom: 4rem;"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/roggers/principal.jpg"
      alt=""
      loading="eager"
      width="1080"
      height="1350"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-black/20"></div>
  </div>

  <!-- Content -->
  <div class="site-container z-10 w-full text-center">
    <p class="label-sm mb-6" style="color: var(--color-primary)">San Juan · Argentina</p>

    <p class="hero-title">
      Noches con sabor &amp; buena música
    </p>
  </div>
</section>

<style>
  .hero-title {
    color: rgba(255,255,255,0.85);
    font-family: 'Bebas Neue', system-ui;
    letter-spacing: 0.04em;
    line-height: 1.05;
    font-size: clamp(2.8rem, 7.5vw, 5.5rem);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: clamp(2.4rem, 11vw, 3.5rem);
    }
  }
</style>
