<style>
  .hero-title {
    color: rgba(255,255,255,0.85);
    font-family: 'Bebas Neue', system-ui;
    letter-spacing: 0.04em;
    line-height: 1.05;
    font-size: clamp(2.2rem, 5.5vw, 4rem);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: clamp(1.8rem, 8.5vw, 2.6rem);
    }
  }

  #hero .btn-primary,
  #hero .btn-ghost {
    font-size: 0.7rem;
    padding: 0.7rem 1.4rem;
  }
</style>
