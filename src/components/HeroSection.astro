<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-end" style="padding-bottom: 3rem;"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/roggers/principal.jpg"
      alt=""
      loading="eager"
      width="1080"
      height="1350"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-black/20"></div>
  </div>

  <!-- Content -->
  <div class="site-container z-10 w-full text-center">
    <p class="label-sm mb-6" style="color: var(--color-primary)">San Juan · Argentina</p>

    <p class="hero-title mb-8">
      Noches con sabor &amp; buena música
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
